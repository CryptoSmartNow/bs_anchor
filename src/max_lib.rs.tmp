use anchor_lang::prelude::*;
use anchor_lang::solana_program::{program::invoke_signed, system_instruction};
use anchor_spl::{
    associated_token::AssociatedToken,
    token::{self, Mint, Token, TokenAccount, Transfer},
};
pub mod errors;
pub mod events;
pub mod state;
pub mod utils;

use crate::errors::SavingsError;
use crate::events::*;
use crate::state::*;
use crate::utils::*;

declare_id!("SavinG11111111111111111111111111111111111111");

#[program]
pub mod savings {
    use super::*;

    /* ----------------- Admin / Setup ----------------- */

    /// Initialize Config with protocol owner and the Pyth program id you trust.
    pub fn initialize_config(
        ctx: Context<InitializeConfig>,
        owner: Pubkey,
        pyth_program: Pubkey,
    ) -> Result<()> {
        let cfg = &mut ctx.accounts.config;
        cfg.protocol_owner = owner;
        cfg.paused = false;
        cfg.bump = *ctx.bumps.get("config").ok_or(SavingsError::BumpNotFound)?;
        cfg.pyth_program = pyth_program;
        emit!(ConfigInitialized {
            owner,
            pyth_program
        });
        Ok(())
    }

    /// Register or update the oracle feed (Pyth price account) for a given token mint.
    pub fn register_oracle(ctx: Context<RegisterOracle>) -> Result<()> {
        require!(
            ctx.accounts.protocol_signer.key() == ctx.accounts.config.protocol_owner,
            SavingsError::Unauthorized
        );
        let reg = &mut ctx.accounts.oracle_registry;
        reg.token_mint = ctx.accounts.token_mint.key();
        reg.oracle_feed = ctx.accounts.price_feed.key();
        reg.bump = *ctx
            .bumps
            .get("oracle_registry")
            .ok_or(SavingsError::BumpNotFound)?;
        emit!(OracleRegistered {
            mint: reg.token_mint,
            feed: reg.oracle_feed
        });
        Ok(())
    }

    /// Pause/unpause the program
    pub fn set_paused(ctx: Context<SetPaused>, paused: bool) -> Result<()> {
        require!(
            ctx.accounts.protocol_signer.key() == ctx.accounts.config.protocol_owner,
            SavingsError::Unauthorized
        );
        ctx.accounts.config.paused = paused;
        emit!(PausedSet { paused });
        Ok(())
    }

    /* ----------------- User Flows ----------------- */

    /// Create user's Vault/profile PDA
    pub fn join_platform(ctx: Context<JoinPlatform>) -> Result<()> {
        require!(!ctx.accounts.config.paused, SavingsError::Paused);
        let v = &mut ctx.accounts.vault;
        v.user = ctx.accounts.user.key();
        v.total_points = 0;
        v.bump = *ctx.bumps.get("vault").ok_or(SavingsError::BumpNotFound)?;
        emit!(UserJoined { user: v.user });
        Ok(())
    }

    /// Create a new saving (SOL or SPL) and charge fee (flat or ~$1 via Pyth).
    pub fn create_saving(
        ctx: Context<CreateSaving>,
        saving_id: u64,
        name: String,
        amount: u64,
        penalty_bps: u16,
        target: Option<u64>,
        maturity_ts: i64,
        fee_mode: FeeMode,
    ) -> Result<()> {
        require!(!ctx.accounts.config.paused, SavingsError::Paused);
        require!(name.len() as u32 <= NAME_MAX_LEN, SavingsError::NameTooLong);
        require!(penalty_bps <= 10_000, SavingsError::InvalidBps);

        // Init Saving
        let s = &mut ctx.accounts.saving;
        s.user = ctx.accounts.user.key();
        s.saving_id = saving_id;
        s.name = name;
        s.penalty_bps = penalty_bps;
        s.target = target;
        s.maturity_ts = maturity_ts;
        s.start_ts = Clock::get()?.unix_timestamp;
        s.token_mint = ctx.accounts.token_mint.key();
        s.amount = 0;
        s.status = SavingStatus::Active;
        s.vault_bump = ctx.accounts.vault.bump;
        s.bump = *ctx.bumps.get("saving").ok_or(SavingsError::BumpNotFound)?;

        // Ensure FeeVault exists (for SPL) and has an ATA; for SOL we won't use FeeVault ATA.
        if !is_native_sol(&s.token_mint) {
            if ctx.accounts.fee_vault.data_is_empty() {
                // init FeeVault
                let fv = &mut ctx.accounts.fee_vault_account.as_ref().unwrap();
                fv.token_mint = s.token_mint;
                fv.vault_ata = ctx.accounts.fee_vault_ata.as_ref().unwrap().key();
                fv.collected = 0;
                fv.bump = *ctx
                    .bumps
                    .get("fee_vault_account")
                    .ok_or(SavingsError::BumpNotFound)?;
            }
        }

        // Compute fee
        let fee_units = compute_fee_usd_or_flat(
            &fee_mode,
            &ctx.accounts.token_mint,
            ctx.accounts.price_feed.as_ref(),
            &ctx.accounts.config.pyth_program,
        )?;

        // Transfers: amount to user vault custody; fee to FeeVault (SPL) or to protocol owner (SOL path decides policy)
        if is_native_sol(&s.token_mint) {
            // Move (amount + fee) lamports user -> vault PDA
            let total = amount
                .checked_add(fee_units)
                .ok_or(SavingsError::MathOverflow)?;
            invoke_signed(
                &system_instruction::transfer(
                    &ctx.accounts.user.key(),
                    &ctx.accounts.vault.key(),
                    total,
                ),
                &[
                    ctx.accounts.user.to_account_info(),
                    ctx.accounts.vault.to_account_info(),
                    ctx.accounts.system_program.to_account_info(),
                ],
                &[],
            )?;

            // Immediately move the fee from vault PDA -> protocol owner (to avoid co-mingling)
            let seeds = &[
                b"vault",
                ctx.accounts.user.key.as_ref(),
                &[ctx.accounts.vault.bump],
            ];
            invoke_signed(
                &system_instruction::transfer(
                    &ctx.accounts.vault.key(),
                    &ctx.accounts.owner_account.key(),
                    fee_units,
                ),
                &[
                    ctx.accounts.vault.to_account_info(),
                    ctx.accounts.owner_account.to_account_info(),
                    ctx.accounts.system_program.to_account_info(),
                ],
                &[seeds],
            )?;
        } else {
            // SPL: ensure ATAs, then transfer:
            // user_ata -> vault_ata (amount)
            transfer_spl(
                amount,
                &ctx.accounts
                    .user_ata
                    .as_ref()
                    .ok_or(SavingsError::MissingATA)?
                    .to_account_info(),
                &ctx.accounts
                    .vault_ata
                    .as_ref()
                    .ok_or(SavingsError::MissingATA)?
                    .to_account_info(),
                &ctx.accounts.user.to_account_info(),
                &ctx.accounts.token_program.to_account_info(),
            )?;
            // user_ata -> fee_vault_ata (fee)
            transfer_spl(
                fee_units,
                &ctx.accounts.user_ata.as_ref().unwrap().to_account_info(),
                &ctx.accounts
                    .fee_vault_ata
                    .as_ref()
                    .ok_or(SavingsError::MissingATA)?
                    .to_account_info(),
                &ctx.accounts.user.to_account_info(),
                &ctx.accounts.token_program.to_account_info(),
            )?;
            // bump fee counter
            let fv = &mut ctx.accounts.fee_vault_account.as_ref().unwrap();
            fv.collected = fv
                .collected
                .checked_add(fee_units)
                .ok_or(SavingsError::MathOverflow)?;
        }

        s.amount = s
            .amount
            .checked_add(amount)
            .ok_or(SavingsError::MathOverflow)?;
        ctx.accounts.vault.total_points = ctx
            .accounts
            .vault
            .total_points
            .checked_add(POINTS_PER_CREATE)
            .ok_or(SavingsError::MathOverflow)?;

        emit!(SavingCreated {
            user: s.user,
            saving_id,
            mint: s.token_mint,
            amount_deposited: amount,
            fee_charged: fee_units,
            maturity_ts,
            target,
            penalty_bps
        });
        Ok(())
    }

    /// Add more funds to an existing saving (no fee here by default).
    pub fn increment_saving(ctx: Context<IncrementSaving>, amount: u64) -> Result<()> {
        require!(!ctx.accounts.config.paused, SavingsError::Paused);
        let s = &mut ctx.accounts.saving;
        require!(
            matches!(s.status, SavingStatus::Active),
            SavingsError::NotActive
        );

        if is_native_sol(&s.token_mint) {
            invoke_signed(
                &system_instruction::transfer(
                    &ctx.accounts.user.key(),
                    &ctx.accounts.vault.key(),
                    amount,
                ),
                &[
                    ctx.accounts.user.to_account_info(),
                    ctx.accounts.vault.to_account_info(),
                    ctx.accounts.system_program.to_account_info(),
                ],
                &[],
            )?;
        } else {
            transfer_spl(
                amount,
                &ctx.accounts
                    .user_ata
                    .as_ref()
                    .ok_or(SavingsError::MissingATA)?
                    .to_account_info(),
                &ctx.accounts
                    .vault_ata
                    .as_ref()
                    .ok_or(SavingsError::MissingATA)?
                    .to_account_info(),
                &ctx.accounts.user.to_account_info(),
                &ctx.accounts.token_program.to_account_info(),
            )?;
        }

        s.amount = s
            .amount
            .checked_add(amount)
            .ok_or(SavingsError::MathOverflow)?;
        emit!(SavingIncremented {
            user: s.user,
            saving_id: s.saving_id,
            added: amount,
            new_amount: s.amount
        });
        Ok(())
    }

    /// Withdraw: if matured or target met → no penalty; else apply penalty -> fee vault / owner.
    pub fn withdraw_saving(ctx: Context<WithdrawSaving>) -> Result<()> {
        require!(!ctx.accounts.config.paused, SavingsError::Paused);
        let s = &mut ctx.accounts.saving;
        require!(
            matches!(s.status, SavingStatus::Active),
            SavingsError::NotActive
        );

        let now = Clock::get()?.unix_timestamp;
        let amount = s.amount;

        let target_met = s.target.map(|t| amount >= t).unwrap_or(false);
        let matured = now >= s.maturity_ts;

        let penalty = if matured || target_met {
            0
        } else {
            amount
                .checked_mul(s.penalty_bps as u64)
                .and_then(|x| x.checked_div(10_000))
                .ok_or(SavingsError::MathOverflow)?
        };

        let payout = amount
            .checked_sub(penalty)
            .ok_or(SavingsError::MathOverflow)?;

        if is_native_sol(&s.token_mint) {
            // Penalty to owner
            if penalty > 0 {
                let seeds = &[b"vault", s.user.as_ref(), &[s.vault_bump]];
                invoke_signed(
                    &system_instruction::transfer(
                        &ctx.accounts.vault.key(),
                        &ctx.accounts.owner_account.key(),
                        penalty,
                    ),
                    &[
                        ctx.accounts.vault.to_account_info(),
                        ctx.accounts.owner_account.to_account_info(),
                        ctx.accounts.system_program.to_account_info(),
                    ],
                    &[seeds],
                )?;
            }
            // Payout to user
            let seeds = &[b"vault", s.user.as_ref(), &[s.vault_bump]];
            invoke_signed(
                &system_instruction::transfer(
                    &ctx.accounts.vault.key(),
                    &ctx.accounts.user.key(),
                    payout,
                ),
                &[
                    ctx.accounts.vault.to_account_info(),
                    ctx.accounts.user.to_account_info(),
                    ctx.accounts.system_program.to_account_info(),
                ],
                &[seeds],
            )?;
        } else {
            // SPL: move penalty to FeeVault ATA; payout to user ATA
            if penalty > 0 {
                let seeds = &[b"vault", s.user.as_ref(), &[s.vault_bump]];
                transfer_spl_signed(
                    penalty,
                    &ctx.accounts
                        .vault_ata
                        .as_ref()
                        .ok_or(SavingsError::MissingATA)?
                        .to_account_info(),
                    &ctx.accounts
                        .fee_vault_ata
                        .as_ref()
                        .ok_or(SavingsError::MissingATA)?
                        .to_account_info(),
                    &ctx.accounts.vault.to_account_info(),
                    seeds,
                    &ctx.accounts.token_program.to_account_info(),
                )?;
                // increment fee vault counter
                let fv = &mut ctx.accounts.fee_vault_account.as_ref().unwrap();
                fv.collected = fv
                    .collected
                    .checked_add(penalty)
                    .ok_or(SavingsError::MathOverflow)?;
            }
            // Payout
            let seeds = &[b"vault", s.user.as_ref(), &[s.vault_bump]];
            transfer_spl_signed(
                payout,
                &ctx.accounts.vault_ata.as_ref().unwrap().to_account_info(),
                &ctx.accounts
                    .user_ata
                    .as_ref()
                    .ok_or(SavingsError::MissingATA)?
                    .to_account_info(),
                &ctx.accounts.vault.to_account_info(),
                seeds,
                &ctx.accounts.token_program.to_account_info(),
            )?;
        }

        s.amount = 0;
        s.status = SavingStatus::Withdrawn;
        emit!(SavingWithdrawn {
            user: s.user,
            saving_id: s.saving_id,
            payout,
            penalty
        });
        Ok(())
    }

    /// Drip profits for a single token mint: moves all collected from FeeVault ATA to owner ATA and zeroes counter.
    pub fn drip_profits_for_token(ctx: Context<DripProfitsForToken>) -> Result<()> {
        require!(
            ctx.accounts.protocol_signer.key() == ctx.accounts.config.protocol_owner,
            SavingsError::Unauthorized
        );

        let fv = &mut ctx.accounts.fee_vault_account;
        require!(fv.collected > 0, SavingsError::NothingToDrip);

        // Transfer tokens from fee_vault_ata -> owner_ata
        transfer_spl_signed(
            fv.collected,
            &ctx.accounts.fee_vault_ata.to_account_info(),
            &ctx.accounts.owner_ata.to_account_info(),
            &ctx.accounts.fee_vault.to_account_info(),
            &[b"fee", fv.token_mint.as_ref(), &[fv.bump]],
            &ctx.accounts.token_program.to_account_info(),
        )?;

        emit!(FeesDripped {
            mint: fv.token_mint,
            amount: fv.collected
        });
        fv.collected = 0;
        Ok(())
    }
}

/* ----------------------------- Accounts ----------------------------- */

#[derive(Accounts)]
pub struct InitializeConfig<'info> {
    #[account(
        init,
        payer = payer,
        seeds = [b"config"],
        bump,
        space = Config::SPACE
    )]
    pub config: Account<'info, Config>,
    #[account(mut)]
    pub payer: Signer<'info>,
    pub system_program: Program<'info, System>,
}

#[derive(Accounts)]
pub struct RegisterOracle<'info> {
    pub protocol_signer: Signer<'info>,
    #[account(
        seeds = [b"config"],
        bump = config.bump,
    )]
    pub config: Account<'info, Config>,

    pub token_mint: Account<'info, Mint>,

    /// CHECK: Pyth price feed account; we only check owner matches config.pyth_program
    pub price_feed: AccountInfo<'info>,

    #[account(
        init_if_needed,
        payer = protocol_signer,
        seeds = [b"oracle", token_mint.key().as_ref()],
        bump,
        space = OracleRegistry::SPACE
    )]
    pub oracle_registry: Account<'info, OracleRegistry>,

    pub system_program: Program<'info, System>,
}

#[derive(Accounts)]
pub struct SetPaused<'info> {
    pub protocol_signer: Signer<'info>,
    #[account(
        mut,
        seeds = [b"config"],
        bump = config.bump,
    )]
    pub config: Account<'info, Config>,
}

#[derive(Accounts)]
pub struct JoinPlatform<'info> {
    #[account(mut)]
    pub user: Signer<'info>,

    #[account(seeds = [b"config"], bump = config.bump)]
    pub config: Account<'info, Config>,

    #[account(
        init,
        payer = user,
        seeds = [b"vault", user.key().as_ref()],
        bump,
        space = Vault::SPACE
    )]
    pub vault: Account<'info, Vault>,

    pub system_program: Program<'info, System>,
}

#[derive(Accounts)]
pub struct CreateSaving<'info> {
    #[account(mut)]
    pub user: Signer<'info>,

    #[account(seeds = [b"config"], bump = config.bump)]
    pub config: Account<'info, Config>,

    #[account(mut, seeds = [b"vault", user.key().as_ref()], bump = vault.bump)]
    pub vault: Account<'info, Vault>,

    pub token_mint: Account<'info, Mint>,

    // SPL accounts (optional if native SOL)
    #[account(
        mut,
        constraint = is_native_sol(&token_mint.key()) || user_ata.as_ref().unwrap().owner == user.key() @ SavingsError::BadOwner,
        constraint = is_native_sol(&token_mint.key()) || user_ata.as_ref().unwrap().mint == token_mint.key() @ SavingsError::BadMint,
    )]
    pub user_ata: Option<Account<'info, TokenAccount>>,

    #[account(
        mut,
        constraint = is_native_sol(&token_mint.key()) || vault_ata.as_ref().unwrap().owner == vault.key() @ SavingsError::BadOwner,
        constraint = is_native_sol(&token_mint.key()) || vault_ata.as_ref().unwrap().mint == token_mint.key() @ SavingsError::BadMint,
    )]
    pub vault_ata: Option<Account<'info, TokenAccount>>,

    // FeeVault (SPL only)
    #[account(
        mut,
        seeds = [b"fee", token_mint.key().as_ref()],
        bump,
    )]
    /// CHECK: We init the account below if empty
    pub fee_vault: AccountInfo<'info>,

    #[account(
        init_if_needed,
        payer = user,
        seeds = [b"fee", token_mint.key().as_ref(), b"acct"],
        bump,
        space = FeeVault::SPACE
    )]
    pub fee_vault_account: Option<Account<'info, FeeVault>>,

    #[account(
        mut,
        constraint = is_native_sol(&token_mint.key()) || fee_vault_ata.as_ref().unwrap().owner == fee_vault.key() @ SavingsError::BadOwner,
        constraint = is_native_sol(&token_mint.key()) || fee_vault_ata.as_ref().unwrap().mint == token_mint.key() @ SavingsError::BadMint,
    )]
    pub fee_vault_ata: Option<Account<'info, TokenAccount>>,

    // Oracle: Pyth price feed, required for FeeMode::UsdOne (SPL or SOL)
    pub price_feed: Option<AccountInfo<'info>>,

    #[account(
        init,
        payer = user,
        seeds = [b"saving", user.key().as_ref(), &saving_id.to_le_bytes()],
        bump,
        space = Saving::space_for_name()
    )]
    pub saving: Account<'info, Saving>,

    pub system_program: Program<'info, System>,
    pub token_program: Program<'info, Token>,
    pub associated_token_program: Program<'info, AssociatedToken>,

    /// CHECK: Owner (protocol) receives SOL fees; we only need the pubkey
    #[account(mut)]
    pub owner_account: AccountInfo<'info>,
}

#[derive(Accounts)]
pub struct IncrementSaving<'info> {
    #[account(mut)]
    pub user: Signer<'info>,

    #[account(seeds = [b"config"], bump = config.bump)]
    pub config: Account<'info, Config>,

    #[account(mut, seeds = [b"vault", user.key().as_ref()], bump = vault.bump)]
    pub vault: Account<'info, Vault>,

    #[account(
        mut,
        seeds = [b"saving", user.key().as_ref(), &saving.saving_id.to_le_bytes()],
        bump = saving.bump,
    )]
    pub saving: Account<'info, Saving>,

    pub token_mint: Account<'info, Mint>,

    #[account(
        mut,
        constraint = is_native_sol(&token_mint.key()) || user_ata.as_ref().unwrap().owner == user.key() @ SavingsError::BadOwner,
        constraint = is_native_sol(&token_mint.key()) || user_ata.as_ref().unwrap().mint == token_mint.key() @ SavingsError::BadMint,
    )]
    pub user_ata: Option<Account<'info, TokenAccount>>,

    #[account(
        mut,
        constraint = is_native_sol(&token_mint.key()) || vault_ata.as_ref().unwrap().owner == vault.key() @ SavingsError::BadOwner,
        constraint = is_native_sol(&token_mint.key()) || vault_ata.as_ref().unwrap().mint == token_mint.key() @ SavingsError::BadMint,
    )]
    pub vault_ata: Option<Account<'info, TokenAccount>>,

    pub token_program: Program<'info, Token>,
    pub system_program: Program<'info, System>,
}

#[derive(Accounts)]
pub struct WithdrawSaving<'info> {
    #[account(mut)]
    pub user: Signer<'info>,

    #[account(seeds = [b"config"], bump = config.bump)]
    pub config: Account<'info, Config>,

    #[account(mut, seeds = [b"vault", user.key().as_ref()], bump = vault.bump)]
    pub vault: Account<'info, Vault>,

    #[account(
        mut,
        seeds = [b"saving", user.key().as_ref(), &saving.saving_id.to_le_bytes()],
        bump = saving.bump,
        constraint = saving.user == user.key() @ SavingsError::Unauthorized,
        constraint = vault.user == user.key() @ SavingsError::Unauthorized,
    )]
    pub saving: Account<'info, Saving>,

    pub token_mint: Account<'info, Mint>,

    // SPL accounts
    #[account(
        mut,
        constraint = is_native_sol(&token_mint.key()) || user_ata.as_ref().unwrap().owner == user.key() @ SavingsError::BadOwner,
        constraint = is_native_sol(&token_mint.key()) || user_ata.as_ref().unwrap().mint == token_mint.key() @ SavingsError::BadMint,
    )]
    pub user_ata: Option<Account<'info, TokenAccount>>,

    #[account(
        mut,
        constraint = is_native_sol(&token_mint.key()) || vault_ata.as_ref().unwrap().owner == vault.key() @ SavingsError::BadOwner,
        constraint = is_native_sol(&token_mint.key()) || vault_ata.as_ref().unwrap().mint == token_mint.key() @ SavingsError::BadMint,
    )]
    pub vault_ata: Option<Account<'info, TokenAccount>>,

    // FeeVault (for SPL penalties)
    #[account(
        mut,
        seeds = [b"fee", token_mint.key().as_ref(), b"acct"],
        bump,
    )]
    pub fee_vault_account: Option<Account<'info, FeeVault>>,

    #[account(
        mut,
        constraint = is_native_sol(&token_mint.key()) || fee_vault_ata.as_ref().unwrap().owner == fee_vault.key() @ SavingsError::BadOwner,
        constraint = is_native_sol(&token_mint.key()) || fee_vault_ata.as_ref().unwrap().mint == token_mint.key() @ SavingsError::BadMint,
    )]
    pub fee_vault_ata: Option<Account<'info, TokenAccount>>,

    /// CHECK: Protocol owner (for SOL penalties)
    #[account(mut)]
    pub owner_account: AccountInfo<'info>,

    /// CHECK: FeeVault PDA for SPL penalties (authority for fee_vault_ata)
    #[account(
        seeds = [b"fee", token_mint.key().as_ref()],
        bump,
    )]
    pub fee_vault: AccountInfo<'info>,

    pub token_program: Program<'info, Token>,
    pub system_program: Program<'info, System>,
}

#[derive(Accounts)]
pub struct DripProfitsForToken<'info> {
    pub protocol_signer: Signer<'info>,
    #[account(seeds = [b"config"], bump = config.bump)]
    pub config: Account<'info, Config>,

    #[account(
        mut,
        seeds = [b"fee", token_mint.key().as_ref(), b"acct"],
        bump,
    )]
    pub fee_vault_account: Account<'info, FeeVault>,

    /// CHECK: PDA authority for the fee vault ATA (different PDA than the account)
    #[account(
        seeds = [b"fee", token_mint.key().as_ref()],
        bump,
    )]
    pub fee_vault: AccountInfo<'info>,

    pub token_mint: Account<'info, Mint>,

    #[account(
        mut,
        constraint = fee_vault_ata.owner == fee_vault.key() @ SavingsError::BadOwner,
        constraint = fee_vault_ata.mint == token_mint.key() @ SavingsError::BadMint,
    )]
    pub fee_vault_ata: Account<'info, TokenAccount>,

    #[account(mut)]
    pub owner_ata: Account<'info, TokenAccount>,

    pub token_program: Program<'info, Token>,
}
